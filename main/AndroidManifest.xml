<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.musicplayer">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />

    <application
        android:name=".MusicPlayerApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MusicPlayer"
        android:usesCleartextTraffic="true">

        <!-- Main Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.MusicPlayer">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Login Activity -->
        <activity
            android:name=".LoginActivity"
            android:exported="false"
            android:label="Login"
            android:theme="@style/Theme.MusicPlayer" />

        <!-- Captcha Verify Activity -->
        <activity
            android:name=".CaptchaVerifyActivity"
            android:exported="false"
            android:label="Verification"
            android:theme="@style/Theme.MusicPlayer" />

        <!-- Password Input Activity -->
        <activity
            android:name=".PasswordInputActivity"
            android:exported="false"
            android:label="Password"
            android:theme="@style/Theme.MusicPlayer" />

        <!-- Search Activity -->
        <activity
            android:name=".SearchActivity"
            android:exported="false"
            android:label="Search"
            android:theme="@style/Theme.MusicPlayer" />

        <!-- Search Result Activity -->
        <activity
            android:name=".SearchResultActivity"
            android:exported="false"
            android:label="Search Results"
            android:theme="@style/Theme.MusicPlayer" />

        <!-- Player Activity -->
        <activity
            android:name=".PlayerActivity"
            android:exported="false"
            android:label="Now Playing"
            android:theme="@style/Theme.MusicPlayer" />

        <!-- Playlist Detail Activity -->
        <activity
            android:name=".PlaylistDetailActivity"
            android:exported="false"
            android:label="Playlist"
            android:theme="@style/Theme.MusicPlayer" />

        <!-- Style Playlist Activity -->
        <activity
            android:name=".StylePlaylistActivity"
            android:exported="false"
            android:label="Style Playlist"
            android:theme="@style/Theme.MusicPlayer" />

        <!-- Comment Activity -->
        <activity
            android:name=".CommentActivity"
            android:exported="false"
            android:label="Comments"
            android:theme="@style/Theme.MusicPlayer" />

        <!-- Video Player Activity -->
        <activity
            android:name=".VideoPlayerActivity"
            android:exported="false"
            android:label="Video Player"
            android:configChanges="orientation|screenSize"
            android:theme="@style/Theme.MusicPlayer" />

        <activity android:name=".SettingsActivity" />

    </application>

</manifest>