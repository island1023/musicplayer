<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="32dp"
    android:background="@drawable/bg_login"> <RelativeLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="20dp">

    <TextView
        android:id="@+id/tv_back"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="&lt; 返回"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:paddingEnd="20dp"
        android:clickable="true"
        android:focusable="true"/>
</RelativeLayout>

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_logo"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="输入验证码"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tv_phone_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="验证码已发送至 +86 "
        android:textColor="#DDDDDD"
        android:textSize="14sp"
        android:layout_marginBottom="30dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:background="#DDFFFFFF"
        android:gravity="center_vertical"
        android:layout_marginBottom="30dp">

        <EditText
            android:id="@+id/et_captcha_input"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:hint="请输入6位验证码"
            android:inputType="number"
            android:maxLength="4"
            android:paddingStart="15dp"
            android:letterSpacing="0.2"
            android:textSize="16sp"
            android:background="@null"
            android:textColor="#000000" />

        <View
            android:layout_width="1dp"
            android:layout_height="25dp"
            android:background="#CCCCCC" />

        <TextView
            android:id="@+id/tv_resend_timer"
            android:layout_width="100dp"
            android:layout_height="match_parent"
            android:text="重新发送"
            android:textColor="#000000"
            android:textSize="14sp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_verify_login"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="登 录"
        android:textColor="#FFFFFF"
        android:backgroundTint="#CCCCCC"
        android:enabled="false"
        android:textSize="18sp" />

</LinearLayout>