<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:orientation="vertical">

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_video_type"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="#121212"
        app:tabIndicatorColor="#FF0000"
        app:tabSelectedTextColor="#FFFFFF"
        app:tabTextColor="#888888">
        <com.google.android.material.tabs.TabItem android:text="MV排行" />
        <com.google.android.material.tabs.TabItem android:text="推荐视频" />
    </com.google.android.material.tabs.TabLayout>

    <HorizontalScrollView
        android:id="@+id/hsv_areas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:scrollbars="none">
        <LinearLayout android:id="@+id/ll_area_container" android:orientation="horizontal" />
    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_video_list"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="8dp" />

</LinearLayout>